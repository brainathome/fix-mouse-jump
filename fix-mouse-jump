#!/usr/bin/env bash
# =============================================================================
# fix-mouse-jump — DPI-aware mouse transition fix for multi-monitor setups
# =============================================================================
#
# Scales side monitors via xrandr so that mouse movement between screens with
# different resolutions/DPI values is physically accurate (no "mouse jump").
#
# This solves the same problem as LittleBigMouse (Windows) on Linux/X11 with
# KDE Plasma.
#
# Usage:
#   fix-mouse-jump apply        Apply scaled layout
#   fix-mouse-jump revert       Revert to original layout
#   fix-mouse-jump autostart    Apply with delay (for login autostart)
#   fix-mouse-jump status       Show current monitor configuration
#   fix-mouse-jump help         Show help
#
# Configuration:
#   Copy config.example to ~/.config/fix-mouse-jump/config and edit to match
#   your monitor setup.
#
# License: GPL-3.0
# =============================================================================

set -euo pipefail

# ─── DEFAULT CONFIG ──────────────────────────────────────────────────────────
# Override these in ~/.config/fix-mouse-jump/config

# Monitor output names (use `xrandr --query` to find yours)
LEFT_MONITOR="DP-0"
CENTER_MONITOR="DP-4"
RIGHT_MONITOR="DP-2"

# Native resolutions
LEFT_RES="1920x1080"
CENTER_RES="3840x1600"
RIGHT_RES="1920x1080"

# Refresh rates (Hz) — use `xrandr --query` to find supported rates
LEFT_RATE="144"
CENTER_RATE="144"
RIGHT_RATE="144"

# Scale factor for side monitors
# Calculate: (center_vertical_px / center_physical_mm) / (side_vertical_px / side_physical_mm)
# Example:   (1600 / 370) / (1080 / 336) = 4.32 / 3.21 ≈ 1.35
SCALE="1.35"

# Delay before applying in autostart mode (seconds)
AUTOSTART_DELAY=10

# Re-apply delay to counter kscreen2 resets (seconds)
AUTOSTART_REAPPLY_DELAY=20

# Restart plasmashell after applying (fixes wallpaper rendering)
RESTART_PLASMASHELL=true

# ─── END DEFAULT CONFIG ─────────────────────────────────────────────────────

readonly APP_NAME="fix-mouse-jump"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/${APP_NAME}"
readonly CONFIG_FILE="${CONFIG_DIR}/config"
readonly LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/${APP_NAME}"
readonly LOG_FILE="${LOG_DIR}/${APP_NAME}.log"

# ─── FUNCTIONS ───────────────────────────────────────────────────────────────

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi
}

log_msg() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    mkdir -p "$LOG_DIR"
    echo "$msg" >> "$LOG_FILE"
    echo "$msg"
}

calculate_positions() {
    local left_w left_h center_w center_h right_w right_h

    left_w="${LEFT_RES%%x*}"
    left_h="${LEFT_RES##*x}"
    center_w="${CENTER_RES%%x*}"
    center_h="${CENTER_RES##*x}"
    right_w="${RIGHT_RES%%x*}"
    right_h="${RIGHT_RES##*x}"

    # Scaled dimensions for side monitors
    SCALED_LEFT_W=$(awk "BEGIN { printf \"%.0f\", $left_w * $SCALE }")
    SCALED_LEFT_H=$(awk "BEGIN { printf \"%.0f\", $left_h * $SCALE }")

    # Positions
    CENTER_X=$SCALED_LEFT_W
    RIGHT_X=$(awk "BEGIN { printf \"%.0f\", $SCALED_LEFT_W + $center_w }")

    # Vertical offset — bottom-aligned (monitors sit on the same desk surface)
    VERT_OFFSET=$(awk "BEGIN { printf \"%.0f\", $center_h - $SCALED_LEFT_H }")

    # Revert positions (no scaling)
    REVERT_LEFT_Y=$(( center_h - left_h ))
    REVERT_RIGHT_X=$(( left_w + center_w ))
}

apply_scale() {
    calculate_positions

    log_msg "Applying layout: scale=${SCALE} on ${LEFT_MONITOR} and ${RIGHT_MONITOR}"
    log_msg "  ${LEFT_MONITOR}:   ${LEFT_RES} scaled ${SCALE}x → pos 0x${VERT_OFFSET}"
    log_msg "  ${CENTER_MONITOR}: ${CENTER_RES}          → pos ${CENTER_X}x0 (primary)"
    log_msg "  ${RIGHT_MONITOR}:  ${RIGHT_RES} scaled ${SCALE}x → pos ${RIGHT_X}x${VERT_OFFSET}"

    xrandr \
        --output "$LEFT_MONITOR"   --mode "$LEFT_RES"   --rate "$LEFT_RATE"   --scale "${SCALE}x${SCALE}" --pos "0x${VERT_OFFSET}" \
        --output "$CENTER_MONITOR" --mode "$CENTER_RES" --rate "$CENTER_RATE" --scale "1x1"               --pos "${CENTER_X}x0" --primary \
        --output "$RIGHT_MONITOR"  --mode "$RIGHT_RES"  --rate "$RIGHT_RATE"  --scale "${SCALE}x${SCALE}" --pos "${RIGHT_X}x${VERT_OFFSET}"

    log_msg "Layout applied successfully."
}

sync_kscreen() {
    # Feed kscreen "native" unscaled positions so monitors appear to touch
    # in KDE display settings (no gap warning). The actual xrandr layout
    # with scaling runs independently — kscreen just needs to believe
    # all screens sit side-by-side at their native resolutions.
    local kscreen_dir="${XDG_DATA_HOME:-$HOME/.local/share}/kscreen"
    [[ -d "$kscreen_dir" ]] || return 0

    command -v jq &>/dev/null || {
        log_msg "jq not found, skipping kscreen sync (install jq to fix KDE gap warning)."
        return 0
    }

    # Native (unscaled) dimensions
    local left_w="${LEFT_RES%%x*}"
    local left_h="${LEFT_RES##*x}"
    local center_w="${CENTER_RES%%x*}"
    local center_h="${CENTER_RES##*x}"

    # Native positions — monitors touching, bottom-aligned
    local fake_left_x=0
    local fake_left_y=$(( center_h - left_h ))
    local fake_center_x=$left_w
    local fake_center_y=0
    local fake_right_x=$(( left_w + center_w ))
    local fake_right_y=$(( center_h - left_h ))

    # Find config file containing our center monitor
    local config_file
    config_file=$(grep -rl "\"name\": \"${CENTER_MONITOR}\"" "$kscreen_dir"/[a-f0-9]* 2>/dev/null | head -1 || true)
    [[ -n "$config_file" ]] || return 0

    log_msg "Syncing kscreen config (native positions): $config_file"

    # Write native positions with scale=1 — kscreen sees no gaps
    jq --arg lm "$LEFT_MONITOR" --arg cm "$CENTER_MONITOR" --arg rm "$RIGHT_MONITOR" \
       --argjson lx "$fake_left_x" --argjson ly "$fake_left_y" \
       --argjson cx "$fake_center_x" --argjson cy "$fake_center_y" \
       --argjson rx "$fake_right_x" --argjson ry "$fake_right_y" \
       '
       [.[] |
         if .metadata.name == $lm then
           .pos = {x: $lx, y: $ly} | .scale = 1
         elif .metadata.name == $cm then
           .pos = {x: $cx, y: $cy} | .scale = 1
         elif .metadata.name == $rm then
           .pos = {x: $rx, y: $ry} | .scale = 1
         else .
         end
       ]' "$config_file" > "${config_file}.tmp" && mv "${config_file}.tmp" "$config_file"

    log_msg "kscreen synced: DP-0@${fake_left_x}x${fake_left_y} DP-4@${fake_center_x}x${fake_center_y} DP-2@${fake_right_x}x${fake_right_y}"
}

revert_layout() {
    calculate_positions

    log_msg "Reverting to original layout (no scaling)..."

    xrandr \
        --output "$LEFT_MONITOR"   --mode "$LEFT_RES"   --rate "$LEFT_RATE"   --scale "1x1" --pos "0x${REVERT_LEFT_Y}" \
        --output "$CENTER_MONITOR" --mode "$CENTER_RES" --rate "$CENTER_RATE" --scale "1x1" --pos "${LEFT_RES%%x*}x0" --primary \
        --output "$RIGHT_MONITOR"  --mode "$RIGHT_RES"  --rate "$RIGHT_RATE"  --scale "1x1" --pos "${REVERT_RIGHT_X}x${REVERT_LEFT_Y}"

    log_msg "Reverted to original layout."
}

restart_plasmashell() {
    if [[ "$RESTART_PLASMASHELL" == true ]]; then
        log_msg "Restarting plasmashell..."
        kquitapp5 plasmashell 2>/dev/null || true
        sleep 2
        kstart5 plasmashell &
        disown
        log_msg "Plasmashell restarted."
    fi
}

show_status() {
    echo "═══════════════════════════════════════════════════════════"
    echo "  ${APP_NAME} — Current Monitor Configuration"
    echo "═══════════════════════════════════════════════════════════"
    echo ""
    echo "  Connected monitors:"
    xrandr --query | grep -E "connected " | sed 's/^/    /'
    echo ""
    echo "  Config: ${CONFIG_FILE}"
    echo "  Log:    ${LOG_FILE}"
    echo ""
    if [[ -f "$LOG_FILE" ]]; then
        echo "  Last 5 log entries:"
        tail -5 "$LOG_FILE" | sed 's/^/    /'
    fi
    echo ""
    echo "═══════════════════════════════════════════════════════════"
}

show_help() {
    cat <<'EOF'
fix-mouse-jump — DPI-aware mouse transition fix for multi-monitor setups

USAGE
    fix-mouse-jump <command>

COMMANDS
    apply       Apply scaled monitor layout for smooth mouse transitions
    revert      Revert to original unscaled layout
    autostart   Apply with delay (intended for login autostart)
    status      Show current monitor configuration and log
    help        Show this help message

CONFIGURATION
    Copy the included config.example to:
        ~/.config/fix-mouse-jump/config

    Then edit the monitor names, resolutions, and scale factor to match
    your setup. Use `xrandr --query` to find your monitor output names.

HOW IT WORKS
    On X11, monitors with different DPI cause a "mouse jump" at screen
    edges — the cursor position doesn't match up physically. This tool
    uses xrandr scaling to virtually increase the resolution of lower-DPI
    monitors, so pixel positions correspond to physical positions.

    The scale factor is calculated as:
        (center_px/mm) / (side_px/mm)

    For example:
        Center: 3840x1600 @ 880mm wide  → 4.36 px/mm
        Side:   1920x1080 @ 597mm wide  → 3.22 px/mm
        Scale:  4.36 / 3.22 ≈ 1.35

EXAMPLES
    fix-mouse-jump apply          # Fix mouse jump now
    fix-mouse-jump revert         # Undo the fix
    fix-mouse-jump status         # Check current state
EOF
}

# ─── MAIN ────────────────────────────────────────────────────────────────────

load_config

case "${1:-help}" in
    apply)
        apply_scale
        restart_plasmashell
        # Wait for kscreen to finish writing its config, then patch it
        sleep 3
        sync_kscreen
        echo "Done. Run '$(basename "$0") revert' to undo."
        ;;
    autostart)
        log_msg "Autostart: waiting ${AUTOSTART_DELAY}s for kscreen2..."
        sleep "$AUTOSTART_DELAY"
        apply_scale
        restart_plasmashell
        sleep 3
        sync_kscreen
        log_msg "Autostart: re-applying in ${AUTOSTART_REAPPLY_DELAY}s..."
        sleep "$AUTOSTART_REAPPLY_DELAY"
        apply_scale
        sleep 3
        sync_kscreen
        log_msg "Autostart: complete."
        ;;
    revert)
        revert_layout
        restart_plasmashell
        echo "Reverted to original layout."
        ;;
    status)
        show_status
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Error: Unknown command '$1'" >&2
        show_help
        exit 1
        ;;
esac
